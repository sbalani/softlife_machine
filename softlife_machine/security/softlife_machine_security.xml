<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_softlife" model="ir.module.category">
            <field name="name">SoftLife</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_softlife_machine_user" model="res.groups">
            <field name="name">Machine Fleet / User</field>
            <field name="category_id" ref="module_category_softlife"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_softlife_machine_manager" model="res.groups">
            <field name="name">Machine Fleet / Manager</field>
            <field name="category_id" ref="module_category_softlife"/>
            <field name="implied_ids" eval="[(4, ref('group_softlife_machine_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
